# Neon PostgreSQL (Dashboard → Connection string). Never commit real credentials.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

# Dev: Vite default. Change in production.
FRONTEND_ORIGIN=http://localhost:5173

PORT=5050

# Random secret for signing JWTs (use a long random string in production)
JWT_SECRET=replace-with-at-least-16-random-characters
